# ── Rugby data source ──────────────────────────────────────────────────────────
# Active connector. Options: mock | api_sports | statscore | sportradar
# Use 'mock' during development until a provider is confirmed (see DECISIONS.md D-012)
RUGBY_DATA_SOURCE=mock

# ── Supabase — Backend only (FastAPI + pipeline) ───────────────────────────────
# The frontend Supabase variables are in frontend/.env.example
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── FastAPI ────────────────────────────────────────────────────────────────────
# Secret used to verify JWT tokens from Supabase Auth
# Same value as SUPABASE_JWT_SECRET in your Supabase project settings
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Database (direct connection for migrations) ────────────────────────────────
# Found in: Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# API host and port (defaults shown)
API_HOST=0.0.0.0
API_PORT=8000
# Environment: development | staging | production
APP_ENV=development

# Waiver cycle scheduler — shared secret for POST /leagues/{id}/waivers/process
WAIVER_SCHEDULER_SECRET=change-me-in-production

# ── dbt ───────────────────────────────────────────────────────────────────────
# DuckDB file path for the data pipeline (relative to dbt_project/)
DUCKDB_PATH=../data/rugbydraft.duckdb

# ── Coolify (production only) ──────────────────────────────────────────────────
# These variables are set directly in Coolify — never in this file for production
# COOLIFY_APP_URL=https://rugbydraft.app

# ── Future: data provider API keys (uncomment when provider is confirmed) ──────
# See DECISIONS.md D-012 for provider selection status
# STATSCORE_API_KEY=your-key
# SPORTRADAR_API_KEY=your-key
# DSG_API_KEY=your-key