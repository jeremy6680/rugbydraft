# airflow/.env.example
# Copy to airflow/.env and fill in values for local development.
# Never commit airflow/.env — it is gitignored.

# Airflow
AIRFLOW_SECRET_KEY=changeme-local-only

# Data source — mock until real provider is confirmed (D-012)
RUGBY_DATA_SOURCE=mock
DBT_TARGET=ci

# Supabase PostgreSQL — required only for gold layer and atomic commit
# Leave empty to skip gold + atomic commit tasks in local dev
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=

# FastAPI internal URL — for notify_scores_ready task
FASTAPI_INTERNAL_URL=http://host.docker.internal:8000
PIPELINE_NOTIFY_SECRET=changeme-local-only